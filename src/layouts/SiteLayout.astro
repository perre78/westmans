---
const {
  title = 'Westmans Serviceverkstad',
  description = 'Bilservice i Kramfors – Westmans Serviceverkstad'
} = Astro.props;

import "../styles/styles.css";

const BASE_URL = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  const normalizedBase = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
  const targetPath = path === normalizedBase ? normalizedBase : path;

  if (targetPath === normalizedBase) {
    return currentPath === normalizedBase || currentPath === `${normalizedBase}index.html`;
  }

  return currentPath.startsWith(targetPath);
};
---

<!doctype html>
<html lang="sv">
  <head>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="container nav">
          <a href={BASE_URL} class="logo">
            <img src={`${BASE_URL}img/logo.png`} alt="Westmans Serviceverkstad" />
          </a>

          <button
            class="menu-toggle"
            type="button"
            aria-label="Öppna meny"
            aria-expanded="false"
            aria-controls="site-menu"
          >
            <span></span>
            <span></span>
            <span></span>
          </button>

          <nav id="site-menu">
            <a href={BASE_URL} class:list={{ active: isActive(BASE_URL) }}>Hem</a>
            <a href={`${BASE_URL}verkstaden/`} class:list={{ active: isActive(`${BASE_URL}verkstaden/`) }}>Verkstaden</a>
            <a href={`${BASE_URL}bildelar/`} class:list={{ active: isActive(`${BASE_URL}bildelar/`) }}>Bildelar</a>
            <a href={`${BASE_URL}kontakt/`} class:list={{ active: isActive(`${BASE_URL}kontakt/`) }}>Kontakt</a>
          </nav>
        </div>
      </header>

      <slot />

      <footer class="site-footer">
        <div class="container footer-inner">
          <div class="footer-row">
            <div class="footer-logos">
              <img src={`${BASE_URL}img/fiat-logo.jpg`} alt="Fiat" />
              <img src={`${BASE_URL}img/fiat-professional.jpg`} alt="Fiat Professional" />
              <img src={`${BASE_URL}img/fiat-mrf-logo.jpg`} alt="Motorbranschens Riksförbund" />
            </div>

            <p>&copy; Westmans Serviceverkstad</p>
          </div>
        </div>
      </footer>
    </div>

    <script>
      const menuToggle = document.querySelector('.menu-toggle');
      const siteMenu = document.querySelector('#site-menu');

      if (menuToggle && siteMenu) {
        menuToggle.addEventListener('click', () => {
          const isOpen = siteMenu.classList.toggle('open');
          menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        siteMenu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            siteMenu.classList.remove('open');
            menuToggle.setAttribute('aria-expanded', 'false');
          });
        });
      }
    </script>
  </body>
</html>
