---
const {
  title = 'Westmans Serviceverkstad',
  description = 'Bilservice i Kramfors – Westmans Serviceverkstad'
} = Astro.props;

import "../styles/styles.css";

const BASE_URL = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <header class="site-header">
      <div class="container nav">
        <div class="logo">
          <img src={`${BASE_URL}img/logo.png`} alt="Westmans Serviceverkstad" />
        </div>
        <nav>
          <a href={BASE_URL}>Hem</a>
          <a href={`${BASE_URL}verkstaden/`}>Verkstaden</a>
          <a href={`${BASE_URL}kontakt/`}>Kontakt</a>
          <a href={`${BASE_URL}bildelar/`}>Bildelar</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-row">
          <div class="footer-logos">
            <img src={`${BASE_URL}img/fiat-logo.jpg`} alt="Fiat" />
            <img src={`${BASE_URL}img/fiat-professional.jpg`} alt="Fiat Professional" />
            <img src={`${BASE_URL}img/fiat-mrf-logo.jpg`} alt="Motorbranschens Riksförbund" />
          </div>

          <p>&copy; Westmans Serviceverkstad</p>
        </div>
      </div>
    </footer>
  </body>
</html>