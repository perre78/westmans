---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Tjänster – Westmans Serviceverkstad"
  description="Service, felsökning, hjulinställning och verkstadsarbeten för personbilar, transportbilar och husbilar."
>
  <header class="site-header">
    <div class="container nav">
      <div class="logo">
        <img src="/img/logo.png" alt="Westmans Serviceverkstad">
      </div>
      <nav>
        <a href="/">Hem</a>
        <a href="/verkstaden">Verkstaden</a>
        <a href="/kontakt">Kontakt</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="section" id="kontakt">
    <div class="container contact-box">
        <div>
        <p class="eyebrow">Kontakt</p>
        <h2>Välkommen att kontakta oss</h2>
        <p>
            Hör av dig om du vill boka service, få hjälp med reparation eller har frågor om däck och felsökning.
        </p>
        </div>

        <div class="card contact-card">
        <p><strong>Westmans Serviceverkstad</strong></p>

        <p>
            <a href="https://www.google.com/maps?q=Sandövägen+42,+872+64+Sandöverken" target="_blank" rel="noopener">
            Sandövägen 42<br />
            872 64 Sandöverken
            </a>
        </p>

        <p style="margin-top:6px;">
            <a href="https://www.google.com/maps?q=Sandövägen+42,+872+64+Sandöverken" target="_blank" rel="noopener">
            📍 Visa på karta
            </a>
        </p>

        <p>
            <a href="tel:061233018">0612-330 18</a><br />
            <a href="mailto:mail@westmans.com">mail@westmans.com</a>
        </p>
        </div>
    </div>
    </section>
  </main>
</SiteLayout>